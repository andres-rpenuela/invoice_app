<div class="flex gap-6">
  <div class="card bg-base-100 shadow-md w-1/2">
    <div class="card-body">
      <h4 class="card-title text-primary text-lg font-semibold">Cliente</h4>
      <p class="text-base-content"><span class="font-semibold">Nombre:</span> {{ client().name }} {{ client().lastName }}</p>
      <p class="text-base-content"><span class="font-semibold">Dirección:</span> {{ client().address.street }} {{ client().address.number }}, {{ client().address.city }}, {{ client().address.country }}</p>
    </div>
  </div>
  <div class="card bg-base-100 shadow-md w-1/2">
    <div class="card-body text-right">
      <h4 class="card-title text-secondary text-lg font-semibold">Empresa</h4>
      <p class="text-base-content"><span class="font-semibold">Nombre:</span> {{ company().name }}</p>
      <p class="text-base-content"><span class="font-semibold">Número Fiscal:</span> {{ company().fiscalNumber }}</p>
    </div>
  </div>
</div>

---

<div class="invoice-header bg-base-100 shadow-md rounded-lg mb-6">
  <div class="flex items-center justify-between gap-4 p-4">
    @if( photo() ){
      <img [src]="photo()" alt="Factura Icon" width="48" height="48" class="rounded-full shadow-md mr-4 bg-primary" />
    }@else{
      <img src="https://cdn-icons-png.flaticon.com/512/3135/3135715.png" alt="Factura Icon" width="48" height="48" class="rounded-full shadow-md mr-4 bg-primary" />
    }
    <div class="text-right">
      <h1 class="text-3xl font-semibold text-primary mb-1">Factura</h1>
      <h2 class="text-xl font-medium text-base-content mt-0">{{ title() }} <span class="invoice-id text-base text-secondary font-normal">#{{ numberInvoice() }}</span></h2>
    </div>
  </div>
</div>

---

<div class="flex items-center gap-3 mb-4">
  <img src="https://cdn-icons-png.flaticon.com/512/1828/1828884.png" alt="Componentes Icon" width="28" height="28" class="mr-2 bg-primary rounded-full" />
  <h3 class="text-2xl font-semibold text-primary">Items</h3>
</div>
<table class="min-w-full bg-base-100 rounded-lg shadow-md">
  <thead class="bg-primary text-primary-content">
    <tr>
      <th class="py-2 px-4 text-left text-primary-content font-semibold">Producto</th>
      <th class="py-2 px-4 text-left text-primary-content font-semibold">Cantidad</th>
      <th class="py-2 px-4 text-left text-primary-content font-semibold">Precio</th>
    </tr>
  </thead>
  <tbody>
    @for(item of items(); track item.id){
      <tr class="hover:bg-secondary/10">
        <td class="py-2 px-4 font-medium text-secondary">{{ item.product }}</td>
        <td class="py-2 px-4 text-base-content">{{ item.quantity }}</td>
        <td class="py-2 px-4 text-success font-bold">{{ item.price }}</td>
      </tr>
    }@empty {
      <tr><td colspan="3" class="py-2 px-4 text-base-content text-center">No hay items.</td></tr>
    }
  </tbody>
</table>


---

<div class="invoice-wrapper">
  <app-invoice-head
    [photo]="'data:image/jpeg;base64,'"
    [numberInvoice]="invoice.id"
    [title]="invoice.name">
  </app-invoice-head>
  <hr>
  <div class="invoice-info">
    <!-- Información del cliente y empresa -->
     <app-invoice-detail
      [client]="invoice.client"
      [company]="invoice.company"
     ></app-invoice-detail>
  </div>
  <div class="invoice-items">
    <!-- Sección de items/componentes -->
    <app-invoice-item [items]="invoice.items"></app-invoice-item>
  </div>
    <!-- Acciones de la factura -->
<!--  <div class="invoice-actions">
    <button class="pdf-btn" (click)="generatePDF()">Generar PDF e Imprimir</button>
  </div>
-->
</div>
